# ---------- Required ----------

# PostgreSQL connection string
DATABASE_URI=postgres://payload:CHANGE_ME@postgres:5432/sdfla_cms

# Long random string used for signing JWTs, cookies, and encrypting secrets.
# Generate with: openssl rand -base64 48
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ---------- Public URL ----------

# The public URL where this Payload admin runs.
PAYLOAD_PUBLIC_SERVER_URL=https://sdfla-cms.kallada.me
NEXT_PUBLIC_SERVER_URL=https://sdfla-cms.kallada.me

# ---------- Astro rebuild webhook ----------

# Coolify deploy webhook URL for the Astro static site. Fires on any content change.
# Get this from Coolify app settings -> "Deploy Keys" -> "Webhook URL".
ASTRO_REBUILD_WEBHOOK=https://72.61.248.12:8000/api/v1/deploy?uuid=t0gkgcks8k8o4gsog8kw8s04

# ---------- CORS ----------

# Comma-separated origins that can call the Payload REST/GraphQL APIs.
# The Astro site needs to be listed here so the build can fetch.
CORS_ORIGINS=https://sdfamilylaw.kallada.me,http://localhost:4321
CSRF_ORIGINS=https://sdfla-cms.kallada.me

# ---------- Optional ----------

# Read-only API token for the Astro build to fetch content. Generate via the
# Payload admin -> Users -> create a read-only user -> generate API key.
ASTRO_BUILD_API_KEY=
